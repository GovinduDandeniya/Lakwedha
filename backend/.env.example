# -----------------------------------------------------------------------------
# LAKWEDHA - Backend Environment Template
# -----------------------------------------------------------------------------

PORT=5000
MONGODB_URI=mongodb://127.0.0.1:27017/lakwedha
NODE_ENV=development
JWT_SECRET=your_jwt_secret_here

# STRIPE CONFIGURATION
# IMPORTANT: The Secret Key MUST NEVER be exposed to the client or version control.
STRIPE_SECRET_KEY=sk_test_xxxx

# The Publishable Key is safe to send to the mobile/web app as it identifies the account only.
STRIPE_PUBLISHABLE_KEY=pk_test_xxxx

# Webhook Secret (Optional but recommended for production)
STRIPE_WEBHOOK_SECRET=whsec_xxxx

# BACKEND API DOMAIN (Used by Stripe to return users)
BACKEND_BASE_URL=http://localhost:5000

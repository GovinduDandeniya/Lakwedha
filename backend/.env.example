# -----------------------------------------------------------------------------
# LAKWEDHA - Backend Environment Template
# -----------------------------------------------------------------------------

PORT=5000
MONGODB_URI=mongodb://127.0.0.1:27017/lakwedha
NODE_ENV=development
JWT_SECRET=your_jwt_secret_here

# PayHere merchant ID from your PayHere dashboard under Integrations
PAYHERE_MERCHANT_ID=

# PayHere merchant secret generated for your domain under Integrations
PAYHERE_MERCHANT_SECRET=

# Set to true for sandbox testing, false for live
PAYHERE_SANDBOX=true

# Your backend public URL needed for PayHere notify_url
BACKEND_URL=http://localhost:5000
